<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only manifest overlay. Merged with main manifest by AGP for the
  `debug` build variant only. Adds networkSecurityConfig pointing to the
  debug-only XML that whitelists 10.0.2.2 / localhost for cleartext HTTP.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:networkSecurityConfig="@xml/network_security_config"
        tools:replace="android:networkSecurityConfig" />
</manifest>
